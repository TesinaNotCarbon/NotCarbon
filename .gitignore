# Foundry build artifacts and cache
cache/
out/

# Foundry broadcasts and runs
# Keep folder in repo but ignore local/dev chain outputs and dry-runs.
!/broadcast/
/broadcast/*/31337/
/broadcast/**/dry-run/
!/broadcast/**/run-latest.json

